{
  "name": "tree-iteration",
  "version": "0.2.1",
  "description": "Tree structure with Zipper iteration",
  "keywords": [
    "tree",
    "node",
    "zipper"
  ],
  "author": "Marco van Kampen <m.kampen@hotmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs"
    },
    "./zipper": {
      "types": "./dist/zipper.d.ts",
      "import": "./dist/zipper.mjs",
      "require": "./dist/zipper.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "dist": "dist",
    "tests": "tests"
  },
  "scripts": {
    "lint": "eslint src eslint.config.js esbuild.config.js jest.config.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "build": "npm run clean && node esbuild.config.js && tsc",
    "clean": "rm -rf ./dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvkampen/tree-iteration.git"
  },
  "bugs": {
    "url": "https://github.com/mvkampen/tree-iteration/issues"
  },
  "homepage": "https://github.com/mvkampen/tree-iteration#readme",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "jest-cli": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {}
}
